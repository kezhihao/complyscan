{
  "name": "complyscan",
  "version": "0.1.0",
  "description": "Small team code compliance scanning - 1/3 the price of Snyk",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx watch src/server.ts",
    "deploy": "wrangler deploy",
    "deploy:vercel": "vercel --prod",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "keywords": [
    "security",
    "compliance",
    "license",
    "scanning",
    "github-actions"
  ],
  "author": "Auto Company",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/better-sqlite3": "^7.6.12",
    "eslint": "^10.0.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vercel": "^50.22.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.68.0"
  }
}
